# Smartsheet API (required for data fetch)
SMARTSHEET_API_TOKEN=
SMARTSHEET_API_BASE_URL=https://api.smartsheet.com/2.0
# SMARTSHEET_CONNECTIONS_JSON={"default":{"token":"token-here","apiBaseUrl":"https://api.smartsheet.com/2.0"}}

# Optional: durable admin-user and config storage for Railway and other production deployments.
# Without DATABASE_URL, managed admins and view/source config use local JSON files (fine for local dev, not durable in production).
# Use verify-full (or your provider's recommended mode) in DATABASE_URL when possible.
# sslmode=no-verify in DATABASE_URL is ignored unless SMARTSHEETS_VIEW_DATABASE_INSECURE_SSL=true.
# DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=verify-full
# Last resort if Postgres TLS verification fails: enables sslmode=no-verify + rejectUnauthorized=false.
# SMARTSHEETS_VIEW_DATABASE_INSECURE_SSL=true
# Optional: explicit external origin for {{PUBLIC_URL}} in custom headers.
# Set this if the app sits behind an unusual proxy/load balancer or you do not want host/proto inferred from trusted proxy headers.
# SMARTSHEETS_VIEW_PUBLIC_BASE_URL=https://catalog.example.edu
# Optional override for trusting x-forwarded-* headers for rate limiting and public URL generation.
# Railway and Vercel are trusted automatically; set true/false explicitly on unusual proxy setups.
# SMARTSHEETS_VIEW_TRUST_PROXY_HEADERS=true

# Admin builder (required for /admin and /api/admin routes)
SMARTSHEETS_VIEW_ADMIN_USERNAME=
SMARTSHEETS_VIEW_ADMIN_PASSWORD=
# Strongly recommended in production: long random secret for signing admin cookies (independent of the password above).
# If unset, the app derives signing material from username+password; changing the password then invalidates all admin sessions.
# SMARTSHEETS_VIEW_ADMIN_SESSION_SECRET=
